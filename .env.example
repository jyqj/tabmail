# --- Required secrets ---
TABMAIL_ADMINKEY=replace-with-long-random-admin-key
TABMAIL_MAILBOX_TOKEN_SECRET=replace-with-long-random-mailbox-token-secret
TABMAIL_REDIS_PASSWORD=replace-with-strong-redis-password

# --- Database / cache ---
POSTGRES_USER=tabmail
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=tabmail
TABMAIL_DB_DSN=postgres://tabmail:replace-with-strong-postgres-password@postgres:5432/tabmail?sslmode=disable
TABMAIL_REDIS_ADDR=redis:6379

# --- Network / role ---
TABMAIL_ROLE=all
TABMAIL_SMTP_DOMAIN=mail.example.com
TABMAIL_HTTP_ALLOWED_ORIGINS=https://tabmail.example.com
TABMAIL_HTTP_TRUSTED_PROXIES=10.0.0.0/8,192.168.0.0/16,127.0.0.1/32

# --- Common runtime ---
TABMAIL_LOGLEVEL=info
TABMAIL_OBJECTSTORE=fs
TABMAIL_DATADIR=/data
TABMAIL_HTTP_ADDR=0.0.0.0:8080
TABMAIL_SMTP_ADDR=0.0.0.0:2525
TABMAIL_MONITORHISTORY=50

# --- Durable ingest / webhook workers ---
TABMAIL_INGEST_DURABLE=true
TABMAIL_INGEST_POLL_INTERVAL=1s
TABMAIL_INGEST_BATCH_SIZE=100
TABMAIL_INGEST_MAX_RETRIES=5
TABMAIL_WEBHOOK_POLL_INTERVAL=1s
TABMAIL_WEBHOOK_BATCH_SIZE=100

# --- Optional webhook ---
# TABMAIL_WEBHOOK_URLS=https://hooks.example.com/tabmail
# TABMAIL_WEBHOOK_SECRET=replace-with-webhook-signing-secret

# --- Optional S3 / MinIO object storage ---
# TABMAIL_OBJECTSTORE=s3
# TABMAIL_S3_ENDPOINT=minio:9000
# TABMAIL_S3_REGION=us-east-1
# TABMAIL_S3_BUCKET=tabmail
# TABMAIL_S3_ACCESS_KEY=minioadmin
# TABMAIL_S3_SECRET_KEY=replace-with-s3-secret
# TABMAIL_S3_USE_TLS=false
# TABMAIL_S3_FORCE_PATH_STYLE=true
# TABMAIL_S3_RESTORE_DELETE=false

# --- Optional monitoring stack ---
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=replace-with-grafana-password

# --- Optional SMTP TLS ---
# TABMAIL_SMTP_TLSENABLED=true
# TABMAIL_SMTP_TLSCERT=/certs/fullchain.pem
# TABMAIL_SMTP_TLSKEY=/certs/privkey.pem
